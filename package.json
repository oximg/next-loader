{
  "name": "@oximg/next-loader",
  "version": "0.1.0",
  "description": "Next.js image loader for a self-hosted oximg server — move image optimization off Vercel/sharp and onto your own box.",
  "keywords": [
    "nextjs",
    "next-image",
    "image-loader",
    "oximg",
    "image-optimization",
    "image-cdn",
    "sharp-alternative"
  ],
  "homepage": "https://github.com/oximg/oximg/tree/main/next-loader",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oximg/oximg.git",
    "directory": "next-loader"
  },
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./sign": {
      "import": {
        "types": "./dist/sign.d.mts",
        "default": "./dist/sign.mjs"
      },
      "require": {
        "types": "./dist/sign.d.cts",
        "default": "./dist/sign.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "build": "tsdown src/index.ts src/sign.ts --format esm,cjs --dts --platform node --clean --treeshake",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test",
    "check": "oxlint && oxfmt --check src test && tsc --noEmit && vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
}
